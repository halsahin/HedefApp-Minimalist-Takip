# AdMob - Gerçek değerleri buraya kopyala ve dosyayı .env olarak kaydet
# Bu dosya örnek şablon olarak GitHub'da kalabilir (gerçek ID içermiyor)

# AdMob App ID'leri (app.config.js tarafından build sırasında kullanılır)
ADMOB_ANDROID_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
ADMOB_IOS_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX

# Ad Unit ID'leri (uygulama içinde reklamı yüklemek için)
EXPO_PUBLIC_ANDROID_AD_UNIT_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_IOS_AD_UNIT_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
